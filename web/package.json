{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "cross-env SKIP_ENV_VALIDATION=1 next build --webpack",
    "start": "next start",
    "env:encrypt": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/env-encrypt.ps1",
    "env:decrypt": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/env-decrypt.ps1",
    "build:schools": "node scripts/build-schools-index.mjs",
    "sync:jp-holidays": "node scripts/sync-jp-national-holidays.mjs",
    "data:jp-anniversaries": "node scripts/fetch-zatsuneta-anniversaries.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "verify-interest-urls": "npx --yes tsx ./verify-interest-urls.mts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google-cloud/tasks": "^6.2.1",
    "@google/genai": "^1.51.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "browser-image-compression": "^2.0.2",
    "googleapis": "^171.4.0",
    "idb": "^8.0.3",
    "japanese-holidays": "^1.0.10",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "redis": "^4.7.1",
    "suncalc": "^1.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/japanese-holidays": "^1.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/suncalc": "^1.9.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "iconv-lite": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
