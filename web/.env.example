# App
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# 本番で snap.yutok.dev に公開 URL を揃える場合: /home /privacy /terms が別ホストから開かれたとき
# https://snap.yutok.dev<path> へリダイレクトします。ローカル（localhost）は対象外です。
# SNAP_MARKETING_HOST=snap.yutok.dev

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-hex
AUTH_TRUST_HOST=true
# Production: canonical public URL (recommended behind Cloud Run / reverse proxy)
AUTH_URL=https://snap.yutok.dev
# Optional: set to 1 for Auth.js debug logs while troubleshooting
# AUTH_DEBUG=1

AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# Access: allowlist (default) = comma-separated ALLOWED_EMAILS, or * / ALL for any Google user.
#         open = any Google sign-in allowed; ALLOWED_EMAILS can be omitted.
AUTH_ACCESS_MODE=allowlist
# AUTH_ACCESS_MODE=open
ALLOWED_EMAILS=your.email@gmail.com

# Database
DATABASE_URL=postgresql://daily_snap:daily_snap_dev@localhost:5432/daily_snap?schema=public

# Storage (local MVP)
UPLOADS_DIR=../.uploads

# OpenAI
OPENAI_API_KEY=replace-me
# 開口ターンのみ Chat Completions の temperature（gpt-5 / o 系は未指定扱い）。空または omit で API 既定。
# OPENAI_ORCHESTRATOR_OPENING_TEMPERATURE=0.72

# Optional: OAuth トークンを暗号化して DB に保存する場合（32 bytes base64）
# TOKEN_ENCRYPTION_KEY=
