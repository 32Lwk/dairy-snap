// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EncryptionMode {
  STANDARD
  EXPERIMENTAL_E2EE
}

enum ImageKind {
  UPLOADED
  GENERATED
}

enum WeatherPeriod {
  AM
  PM
}

enum ArtifactKind {
  CHAT_MESSAGE
  JOURNAL_DRAFT
  TITLE_SUGGESTION
  TAG_SUGGESTION
  DAILY_SUMMARY
  IMPACT_ESTIMATE
  EMBEDDING
  IMAGE_PROMPT
  SETTINGS_PATCH
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  isAllowed Boolean @default(false)
  timeZone  String  @default("Asia/Tokyo")

  encryptionMode EncryptionMode @default(STANDARD)
  settings       Json           @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  dailyEntries   DailyEntry[]
  usageCounters  UsageCounter[]
  oauthTokens    OAuthToken[]
  auditLogs      AuditLog[]
  aiArtifacts    AIArtifact[]
  memories       MemoryLongTerm[]
  agentMemories  AgentMemory[]
  agentEvals     AgentEvaluation[]
  securityReviews SecurityReview[]
  tags           Tag[]
  gcalEventCache GoogleCalendarEventCache[]
  gcalSyncState  GoogleCalendarSyncState[]
  googlePhotoSelections GooglePhotoSelection[]
  memoryShortTerms MemoryShortTerm[]
  appLocalCalendars     AppLocalCalendar[]
  appLocalCalendarEvents AppLocalCalendarEvent[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model DailyEntry {
  id           String @id @default(cuid())
  userId       String
  entryDateYmd String

  title String?
  mood  String?
  body  String

  latitude  Float?
  longitude Float?

  weatherPeriod WeatherPeriod?
  weatherJson   Json? // Open-Meteoレスポンスの必要部分（MVPは柔軟に）

  encryptionMode EncryptionMode @default(STANDARD)
  encryptionMeta Json           @default("{}")

  /** プルチック8原感情の分析結果（JSON）。schemaVersion 等を含む。 */
  plutchikAnalysis Json?
  /** plutchikAnalysis.primary の最大スコア感情（英語キー）。検索・集計用。 */
  dominantEmotion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  appendEvents EntryAppendEvent[]
  images       Image[]
  googlePhotoSelections GooglePhotoSelection[]
  entryTags    EntryTag[]
  chatThreads  ChatThread[]
  aiArtifacts  AIArtifact[]
  auditLogs    AuditLog[]
  memoryShortTerms      MemoryShortTerm[]
  memoryLongTermSources MemoryLongTerm[] @relation("MemoryLongTermSourceEntry")

  @@unique([userId, entryDateYmd])
  @@index([userId, entryDateYmd])
  @@index([userId, dominantEmotion])
  @@map("daily_entries")
}

model EntryAppendEvent {
  id         String   @id @default(cuid())
  entryId    String
  occurredAt DateTime
  fragment   String

  createdAt DateTime @default(now())

  entry DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, occurredAt])
  @@map("entry_append_events")
}

model Image {
  id      String    @id @default(cuid())
  entryId String
  kind    ImageKind

  storageKey String
  mimeType   String
  byteSize   Int
  sha256     String?

  /** Google Photos Picker の mediaItemId（同一枚の重複保存防止用・任意） */
  googleMediaItemId String?

  /** UI表示用の回転（0,1,2,3 で 0/90/180/270 度）。画像データ自体は回転しない。 */
  rotationQuarterTurns Int @default(0)
  /** 画像に付ける一言メモ（キャプション） */
  caption String @default("")

  width  Int?
  height Int?

  createdAt DateTime @default(now())

  entry DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([entryId, googleMediaItemId])
  @@map("images")
}

model GooglePhotoSelection {
  id String @id @default(cuid())

  userId       String
  entryId      String?
  entryDateYmd String

  providerSessionId String?
  mediaItemId       String
  baseUrl           String
  productUrl        String?
  mimeType          String?
  filename          String?
  width             Int?
  height            Int?
  creationTime      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry DailyEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@unique([userId, entryDateYmd, mediaItemId])
  @@index([userId, entryDateYmd])
  @@index([entryId])
  @@map("google_photo_selections")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryTags EntryTag[]

  @@unique([userId, name])
  @@map("tags")
}

model EntryTag {
  entryId String
  tagId   String

  entry DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag   Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@map("entry_tags")
}

model GoogleCalendarEventCache {
  id String @id @default(cuid())

  userId     String
  calendarId String
  eventId    String

  /** UI用: カレンダー名（取得できた場合） */
  calendarName String?
  /** カレンダー色（calendarList.colorId。取得できた場合） */
  calendarColorId String?
  /** イベント色（event.colorId。設定されている場合） */
  eventColorId String?

  title       String
  location    String
  description String

  /// Google Calendar API event snapshot
  eventPayload Json?
  /// Denormalized text for search/embeddings
  eventSearchBlob String @default("")

  startIso String
  endIso   String
  startAt  DateTime
  endAt    DateTime

  /**
   * UI/分類用の固定カテゴリ（イベント単位）。
   * null の場合はルール/ヒント/プロフィールシグナルで推定する。
   */
  fixedCategory String?

  isCancelled   Boolean   @default(false)
  updatedAtGcal DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, calendarId, eventId])
  @@index([userId, startAt])
  @@index([userId, endAt])
  @@map("google_calendar_event_cache")
}

model GoogleCalendarSyncState {
  id String @id @default(cuid())

  userId     String
  calendarId String

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, calendarId])
  @@map("google_calendar_sync_state")
}

/// Google 以外に、このアプリの DB だけに保存するカレンダー
model AppLocalCalendar {
  id     String @id @default(cuid())
  userId String
  name   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events AppLocalCalendarEvent[]

  @@index([userId])
  @@map("app_local_calendars")
}

model AppLocalCalendarEvent {
  id          String @id @default(cuid())
  userId      String
  calendarId  String
  title       String
  description String @default("")
  location    String @default("")
  startIso    String
  endIso      String
  startAt     DateTime
  endAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendar AppLocalCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([userId, calendarId])
  @@index([userId, startAt])
  @@map("app_local_calendar_events")
}

model ChatThread {
  id      String  @id @default(cuid())
  entryId String
  title   String?

  /**
   * 会話から抽出した構造化メモ（JSON）
   */
  conversationNotes Json @default("{}")

  /** チャット全文バックフィル（設定の補完）を最後に完了した時刻 */
  memoryChatBackfillAt DateTime?
  /** 上記実行時点のメッセージ件数（件数が変わるまで再バックフィルしない） */
  memoryChatBackfillMsgCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entry    DailyEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([entryId])
  @@map("chat_threads")
}

model ChatMessage {
  id       String @id @default(cuid())
  threadId String
  role     String
  content  String

  model         String?
  latencyMs     Int?
  tokenEstimate Int?
  /** トレース用: "school" | "romance" | "orchestrator" 等 */
  agentName     String?

  createdAt DateTime @default(now())
  /** 開口プレースホルダ→本文確定など、行が更新された時刻（表示は主にこちらを使用） */
  updatedAt DateTime @updatedAt

  thread          ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  securityReview  SecurityReview?

  @@index([threadId, createdAt])
  @@map("chat_messages")
}

/** Async AI security review (rule tags + optional mini-model LLM). One row per assistant message. */
model SecurityReview {
  id        String @id @default(cuid())
  messageId String @unique
  userId    String
  threadId  String
  entryId   String?

  severity String
  /** string[] e.g. prompt_injection, meta_echo */
  categories Json @default("[]")

  model                 String?
  userFacingSummaryJa   String?
  internalNote          String?
  /** string[] sync rule tags passed from hot path */
  syncRuleTags          Json @default("[]")
  llmInvoked             Boolean @default(false)
  replacedContent       Boolean @default(false)

  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([threadId, createdAt])
  @@map("security_reviews")
}

model AIArtifact {
  id            String       @id @default(cuid())
  userId        String
  entryId       String?
  kind          ArtifactKind
  promptVersion String?

  model         String?
  latencyMs     Int?
  tokenEstimate Int?
  cacheKey      String?
  cacheHit      Boolean @default(false)

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry DailyEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("ai_artifacts")
}

model AuditLog {
  id      String  @id @default(cuid())
  userId  String
  entryId String?

  action   String
  metadata Json   @default("{}")

  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry DailyEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("audit_logs")
}

model OAuthToken {
  id       String @id @default(cuid())
  userId   String
  provider String

  tokenCiphertext String
  tokenMeta       Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("oauth_tokens")
}

model MemoryLongTerm {
  id            String  @id @default(cuid())
  userId        String
  sourceEntryId String?

  bullets     Json // 箇条書き（抽象化）
  attributes  Json  @default("{}")
  impactScore Float @default(0)

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEntry DailyEntry? @relation("MemoryLongTermSourceEntry", fields: [sourceEntryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, sourceEntryId])
  @@map("memory_long_term")
}

/** Per-diary-entry short-term bullets extracted after chat (MAS). */
model MemoryShortTerm {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  bullets   Json
  salience  Float    @default(0.5)
  dedupKey  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([userId, entryId])
  @@index([entryId])
  @@map("memory_short_term")
}

model Embedding {
  id         String @id @default(cuid())
  userId     String
  targetType String
  targetId   String

  model      String
  dimensions Int
  vector     Unsupported("vector")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, targetType, targetId])
  @@map("embeddings")
}

model UsageCounter {
  id      String @id @default(cuid())
  userId  String
  dateYmd String

  chatMessages      Int @default(0)
  imageGenerations  Int @default(0)
  dailySummaries    Int @default(0)
  /** オーケストレーター呼び出し回数（可視化用・レート制限なし） */
  orchestratorCalls Int @default(0)
  /** 記憶サブエージェント（ターン抽出・日記統合・スレッド整合）の LLM 呼び出し回数／日（将来の上限用） */
  memorySubAgentCalls Int @default(0)
  /** チャット経由の設定自動適用（成功時にインクリメント／日） */
  settingsChanges Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateYmd])
  @@map("usage_counters")
}

model AgentMemory {
  id     String @id @default(cuid())
  userId String
  /** "school" | "calendar_daily" | "calendar_work" | "calendar_social" | "hobby" | "romance" */
  domain String
  /** 例: "preferred_study_time", "parttime_employer", "partner_name" */
  memoryKey   String
  memoryValue String
  confidence  Float    @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, memoryKey])
  @@index([userId, domain])
  @@map("agent_memories")
}

model AgentEvaluation {
  id       String @id @default(cuid())
  userId   String
  threadId String

  agentsUsed    String[]
  routingScore  Float?
  qualityScore  Float?
  /** ペルソナ遵守スコア */
  personaScore  Float?
  notes         Json     @default("{}")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("agent_evaluations")
}
